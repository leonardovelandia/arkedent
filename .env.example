# ══════════════════════════════════════════════════════════════════
#  Sistema Tatiana Velandia Odontología — Configuración de entorno
#  Copia este archivo como .env y ajusta los valores según el entorno
# ══════════════════════════════════════════════════════════════════

APP_NAME="Tatiana Velandia Odontología"
APP_KEY=

# ──────────────────────────────────────────
# ENTORNO LOCAL (Laragon / desarrollo)
# ──────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_URL=http://tatianavelandia.test

# ──────────────────────────────────────────
# ENTORNO PRODUCCIÓN (nube / servidor VPS)
# Descomentar estas líneas y comentar las de arriba
# ──────────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ──────────────────────────────────────────
# LOGS
# local: debug | producción: error
# ──────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_LEVEL=error   ← usar en producción

# ──────────────────────────────────────────
# BASE DE DATOS (MySQL / MariaDB)
# ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tatianavelandia
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ──────────────────────────────────────────
# COLAS
# local: sync (sin worker) | producción: database o redis
# ──────────────────────────────────────────
QUEUE_CONNECTION=sync
# QUEUE_CONNECTION=database   ← usar en producción con: php artisan queue:work

CACHE_STORE=file
# CACHE_STORE=redis   ← usar en producción para mayor rendimiento

# ──────────────────────────────────────────
# CORREO — SendGrid SMTP
# El nombre del remitente (MAIL_FROM_NAME) se sobreescribe
# automáticamente con el nombre del consultorio desde la BD.
# ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=tu_api_key_de_sendgrid
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@tu-dominio.com
MAIL_FROM_NAME="Tatiana Velandia Odontología"

# ── Alternativa local (sin enviar correos reales) ──
# MAIL_MAILER=log        ← guarda en storage/logs/laravel.log
# MAIL_MAILER=mailtrap   ← usar con cuenta de mailtrap.io para pruebas

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ──────────────────────────────────────────
# PANEL DEV — cambiar en producción
# ──────────────────────────────────────────
DEV_PASSWORD=

# ──────────────────────────────────────────
# WHATSAPP
# ──────────────────────────────────────────
ULTRAMSG_TOKEN=
ULTRAMSG_INSTANCE=

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ──────────────────────────────────────────
# FACTURACIÓN ELECTRÓNICA
# ──────────────────────────────────────────
FACTURACION_PROVEEDOR=
ALEGRA_API_KEY=
PLEMSI_API_KEY=
SIIGO_USERNAME=
SIIGO_ACCESS_KEY=
